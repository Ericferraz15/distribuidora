# Copie para .env e ajuste os valores.

# Chave que assina os JWT. OBRIGATORIA, minimo 32 caracteres (a API se recusa
# a subir com chave fraca). Gere a sua com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY_JWT="troque-por-uma-chave-aleatoria-com-32+-caracteres"

# Conexao PostgreSQL (SQLAlchemy + driver psycopg 3).
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/distribuidora"

# Bootstrap do admin inicial (usado por scripts/seed.py).
ADMIN_NOME="admin"
ADMIN_SENHA="admin123"

# Origens liberadas no CORS, separadas por virgula. Em dev pode deixar "*"
# (o proxy do Vite nem usa CORS); em producao na rede local, restrinja ao
# endereco do front, ex.: http://192.168.0.10:3000
CORS_ORIGINS="*"

# Fuso horario do negocio: define o que conta como "dia" no dashboard.
# Os timestamps continuam gravados em UTC no banco.
FUSO_NEGOCIO="America/Sao_Paulo"

# Interface onde o painel (porta 80) escuta. O instalar.sh ajusta sozinho:
# 127.0.0.1 = so esta maquina; 0.0.0.0 = rede local toda (notebook da loja).
PAINEL_BIND=127.0.0.1
